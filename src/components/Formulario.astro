---
const services = [
  "Medicina Estética",
  "Tratamientos Faciales",
  "Tratamientos Corporales",
  "Labios & Rellenos",
  "Micropigmentación",
  "Nutrición & Bienestar",
  "Otro / Consulta general",
];

const trustItems = [
  "Primera consulta completamente gratuita",
  "Diagnóstico personalizado sin compromiso",
  "Equipo certificado y especializado",
  "Respuesta en menos de 24 horas",
];
---
<section id="contacto" class="form-section">
  <div class="section-inner">
    <div class="form-grid">

      <!-- Left: Info -->
      <div>
        <span class="section-tag reveal">Reserva tu Cita</span>
        <h2 class="form-info-title reveal reveal-delay-1">
          Tu Primera Consulta es Gratuita
        </h2>
        <p class="form-info-sub reveal reveal-delay-2">
          Analizamos tu piel con tecnología avanzada y diseñamos un plan personalizado
          para ti. Sin compromiso.
        </p>

        <ul class="form-trust-items reveal reveal-delay-3" role="list">
          {trustItems.map((item) => (
            <li class="form-trust-item">
              <span class="form-trust-icon" aria-hidden="true">✓</span>
              {item}
            </li>
          ))}
        </ul>

        <!-- Contact alternatives -->
        <div style="margin-top:2.5rem;" class="reveal reveal-delay-4">
          <p style="font-size:0.8rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:var(--color-primary); margin-bottom:0.875rem;">
            También puedes contactarnos
          </p>
          <a
            href="https://wa.me/34614343492"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
            style="display:inline-flex; align-items:center; gap:0.5rem; background:#25D366;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a href="tel:+34614343492" class="btn-outline" style="margin-left:0.75rem; display:inline-flex; align-items:center; gap:0.4rem;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.06 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            Llamar
          </a>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="reveal reveal-delay-2">
        <form
          class="contact-form"
          name="cita"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/gracias"
          novalidate
        >
          <!-- Netlify hidden input -->
          <input type="hidden" name="form-name" value="cita" />
          <!-- Honeypot -->
          <p style="display:none;"><label>No rellenes esto: <input name="bot-field" /></label></p>
          <!-- UTM hidden fields -->
          <input type="hidden" name="utm_source" value="" />
          <input type="hidden" name="utm_campaign" value="" />
          <input type="hidden" name="utm_medium" value="" />

          <!-- Name + Phone row -->
          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder="Tu nombre"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="form-group">
              <label for="telefono">Teléfono *</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="6XX XXX XXX"
                required
                autocomplete="tel"
              />
            </div>
          </div>

          <!-- Email -->
          <div class="form-group">
            <label for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="tucorreo@ejemplo.com"
              autocomplete="email"
            />
          </div>

          <!-- Service -->
          <div class="form-group">
            <label for="servicio">Servicio de interés *</label>
            <select id="servicio" name="servicio" required>
              <option value="" disabled selected>Selecciona un tratamiento</option>
              {services.map((s) => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </div>

          <!-- Message -->
          <div class="form-group">
            <label for="mensaje">Mensaje (opcional)</label>
            <textarea
              id="mensaje"
              name="mensaje"
              placeholder="Cuéntanos en qué podemos ayudarte..."
              rows="3"
            ></textarea>
          </div>

          <!-- Privacy checkbox -->
          <div class="form-checkbox">
            <input type="checkbox" id="privacidad" name="privacidad" required />
            <label for="privacidad">
              He leído y acepto la{" "}
              <a href="/privacidad" target="_blank">política de privacidad</a>
            </label>
          </div>

          <!-- Submit -->
          <button type="submit" class="btn-primary form-submit">
            Solicitar Cita Gratuita
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
