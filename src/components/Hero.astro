---
---
<section class="hero" id="inicio">
  <div class="hero-inner">
    <!-- Badge -->
    <div class="hero-badge reveal">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
      </svg>
      Cuenta verificada · Ciudad Real
    </div>

    <!-- Heading -->
    <h1 class="hero-title reveal reveal-delay-1">
      Medicina y Estética<br />Avanzada en Ciudad Real
    </h1>

    <!-- Subtitle -->
    <p class="hero-subtitle reveal reveal-delay-2">
      Resultados reales, elevando tu confianza.<br />
      Tu mejor versión empieza con un diagnóstico personalizado.
    </p>

    <!-- Location -->
    <p class="hero-location reveal reveal-delay-3">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      Calle Cruz 2, Ciudad Real
    </p>

    <!-- CTAs -->
    <div class="hero-ctas reveal reveal-delay-4">
      <a href="#contacto" class="btn-primary" style="font-size:1rem; padding: 0.8rem 1.75rem;">
        Reserva tu Consulta Gratuita
      </a>
      <a href="tel:+34614343492" class="btn-outline" style="font-size:1rem; padding: 0.8rem 1.75rem;">
        📞 614 34 34 92
      </a>
    </div>
  </div>

  <!-- Decorative right image area -->
  <div class="hero-image-area" aria-hidden="true">
    <div style="width:100%;height:100%;background:linear-gradient(160deg,#D8E0D2 0%,#C4CDB8 50%,#B8C4AC 100%);display:flex;align-items:center;justify-content:center;">
      <svg width="120" height="120" viewBox="0 0 120 120" fill="none" opacity="0.25">
        <circle cx="60" cy="60" r="58" stroke="#4A5C3D" stroke-width="2"/>
        <path d="M60 20 C60 20, 80 40, 80 60 C80 80, 60 100, 60 100 C60 100, 40 80, 40 60 C40 40, 60 20, 60 20Z" fill="#7A8C6E"/>
        <circle cx="60" cy="60" r="12" fill="#4A5C3D" opacity="0.6"/>
      </svg>
    </div>
  </div>
</section>
