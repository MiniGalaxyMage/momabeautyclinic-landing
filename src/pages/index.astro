---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ============================
       NAVBAR
  ============================= -->
  <nav class="navbar" role="navigation" aria-label="Navegación principal">
    <div class="navbar-inner">
      <a href="/" class="nav-logo" aria-label="MŌMA Beauty Clinic — Inicio">MŌMA</a>

      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-links" id="navLinks" role="list">
        <li><a href="#servicios">Servicios</a></li>
        <li><a href="#nosotros">Nosotros</a></li>
        <li><a href="#equipo">Equipo</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>

      <a href="#contacto" class="btn-primary nav-cta-desktop">Pedir Cita</a>
    </div>
  </nav>

  <!-- ============================
       HERO V2 — Gradient Mesh
  ============================= -->
  <section class="hero-v2" aria-label="Sección principal">
    <div class="mesh-blob mesh-blob-1" aria-hidden="true"></div>
    <div class="mesh-blob mesh-blob-2" aria-hidden="true"></div>
    <div class="mesh-blob mesh-blob-3" aria-hidden="true"></div>

    <div class="hero-v2-inner">
      <div class="hero-badge reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        Ciudad Real · Medicina Estética Premium
      </div>

      <h1 class="hero-v2-title reveal reveal-delay-1">
        Medicina y Estética<br />
        <span class="text-gradient">Avanzada en Ciudad Real</span>
      </h1>

      <p class="hero-v2-subtitle reveal reveal-delay-2">
        Resultados reales, elevando tu confianza. Tu mejor versión empieza
        con un diagnóstico personalizado.
      </p>

      <div class="hero-v2-ctas reveal reveal-delay-3">
        <a href="#contacto" class="btn-primary btn-lg">Reserva tu Consulta Gratuita</a>
        <a href="tel:+34614343492" class="btn-outline btn-lg">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:inline;margin-right:0.25rem">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.1 6.1l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          614 34 34 92
        </a>
      </div>

      <div class="hero-v2-meta reveal reveal-delay-4">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        Calle Cruz 2, Ciudad Real
        <span aria-hidden="true">·</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        L-V 10:00–20:00 · S 10:00–14:00
      </div>
    </div>
  </section>

  <!-- ============================
       SOCIAL PROOF — Counters
  ============================= -->
  <section class="social-proof" aria-label="Cifras destacadas">
    <div class="proof-inner">
      <div class="proof-item reveal">
        <span class="counter" data-target="2000" data-prefix="+" data-suffix="">+2000</span>
        <span class="proof-label">Clientes satisfechos</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-item reveal reveal-delay-1">
        <span class="counter" data-target="132" data-prefix="" data-suffix="">132</span>
        <span class="proof-label">Publicaciones</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-item reveal reveal-delay-2">
        <span class="proof-number">✓</span>
        <span class="proof-label">Cuenta Verificada</span>
      </div>
      <div class="proof-divider" aria-hidden="true"></div>
      <div class="proof-item reveal reveal-delay-3">
        <span class="counter" data-target="10" data-prefix="" data-suffix="+">10+</span>
        <span class="proof-label">Años de experiencia</span>
      </div>
    </div>
  </section>

  <!-- ============================
       CATÁLOGO DE SERVICIOS — Tabs
  ============================= -->
  <section id="servicios" class="catalog-section" aria-labelledby="catalog-title">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag reveal">Menú MŌMA</span>
        <h2 class="section-title reveal reveal-delay-1" id="catalog-title">Catálogo de Servicios y Precios</h2>
        <p class="section-subtitle reveal reveal-delay-2">Todos los tratamientos con sus precios reales. Sin sorpresas.</p>
      </div>

      <!-- Tab Navigation -->
      <div class="catalog-tabs-nav reveal" role="tablist" aria-label="Categorías de servicios">
        <button class="catalog-tab active" role="tab" id="tab-faciales" data-tab="cat-faciales" aria-selected="true" aria-controls="cat-faciales">Faciales</button>
        <button class="catalog-tab" role="tab" id="tab-corporales" data-tab="cat-corporales" aria-selected="false" aria-controls="cat-corporales">Corporales</button>
        <button class="catalog-tab" role="tab" id="tab-masajes" data-tab="cat-masajes" aria-selected="false" aria-controls="cat-masajes">Masajes</button>
        <button class="catalog-tab" role="tab" id="tab-manicura" data-tab="cat-manicura" aria-selected="false" aria-controls="cat-manicura">Manicura</button>
        <button class="catalog-tab" role="tab" id="tab-pedicura" data-tab="cat-pedicura" aria-selected="false" aria-controls="cat-pedicura">Pedicura</button>
        <button class="catalog-tab" role="tab" id="tab-manipedi" data-tab="cat-manipedi" aria-selected="false" aria-controls="cat-manipedi">ManiPedi</button>
        <button class="catalog-tab" role="tab" id="tab-laser" data-tab="cat-laser" aria-selected="false" aria-controls="cat-laser">Láser</button>
        <button class="catalog-tab" role="tab" id="tab-cejas" data-tab="cat-cejas" aria-selected="false" aria-controls="cat-cejas">Cejas & Beauty</button>
      </div>

      <!-- Tab Panels -->
      <div class="catalog-panels">

        <!-- ── FACIALES ── -->
        <div class="catalog-panel active" id="cat-faciales" role="tabpanel" aria-labelledby="tab-faciales">
          <div class="catalog-subgroup-block">
            <h3 class="catalog-subgroup">Limpiezas</h3>
            <div class="catalog-rows">
              <div class="catalog-row">
                <span class="catalog-name">Limpieza de mantenimiento</span>
                <span class="catalog-duration">45 min</span>
                <span class="catalog-price">32,90€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Limpieza con aparatología</span>
                <span class="catalog-duration">60 min</span>
                <span class="catalog-price">44,90€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Limpieza completa con Hydrafacial</span>
                <span class="catalog-duration">75 min</span>
                <span class="catalog-price">55€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Alta frecuencia</span>
                <span class="catalog-duration">20 min</span>
                <span class="catalog-price">14,90€</span>
              </div>
            </div>
          </div>

          <div class="catalog-subgroup-block">
            <h3 class="catalog-subgroup">No Invasivos</h3>
            <div class="catalog-rows">
              <div class="catalog-row">
                <span class="catalog-name">Cromoterapia</span>
                <span class="catalog-duration">30 min</span>
                <span class="catalog-price">20€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Luz pulsada IPL</span>
                <span class="catalog-duration">25 min</span>
                <span class="catalog-price">35€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Cromoterapia avanzada</span>
                <span class="catalog-duration">30 min</span>
                <span class="catalog-price">35€</span>
              </div>
            </div>
          </div>

          <div class="catalog-subgroup-block">
            <h3 class="catalog-subgroup">Avanzados</h3>
            <div class="catalog-rows">
              <div class="catalog-row">
                <span class="catalog-name">Dermapen</span>
                <span class="catalog-duration">25 min</span>
                <span class="catalog-price catalog-price-info">Según activos</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Plasmapen</span>
                <span class="catalog-duration">15–30 min</span>
                <span class="catalog-price catalog-price-info">Según zona</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Radiofrecuencia fraccionada</span>
                <span class="catalog-duration">90 min</span>
                <span class="catalog-price">160€</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ── CORPORALES ── -->
        <div class="catalog-panel" id="cat-corporales" role="tabpanel" aria-labelledby="tab-corporales">
          <div class="catalog-subgroup-block">
            <h3 class="catalog-subgroup">Con aparatología</h3>
            <div class="catalog-rows">
              <div class="catalog-row">
                <span class="catalog-name">Vacuum</span>
                <span class="catalog-duration">45 min</span>
                <span class="catalog-price">34,90€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Radiofrecuencia</span>
                <span class="catalog-duration">60 min</span>
                <span class="catalog-price">39,90€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Cavitación</span>
                <span class="catalog-duration">Según zona</span>
                <span class="catalog-price catalog-price-info">Según zona</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Rayos UVA</span>
                <span class="catalog-duration">Según FTP</span>
                <span class="catalog-price">5,50€/ses. · Bono 10+1: 40€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Plasmapen corporal</span>
                <span class="catalog-duration">Según zona</span>
                <span class="catalog-price catalog-price-info">Según zona</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Presoterapia</span>
                <span class="catalog-duration">20 min</span>
                <span class="catalog-price catalog-price-info">Bono</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">W.O.W</span>
                <span class="catalog-duration">20 min</span>
                <span class="catalog-price catalog-price-info">Bono</span>
              </div>
            </div>
          </div>

          <div class="catalog-subgroup-block">
            <h3 class="catalog-subgroup">Sin aparatología</h3>
            <div class="catalog-rows">
              <div class="catalog-row">
                <span class="catalog-name">Higiene de espalda</span>
                <span class="catalog-duration">20–30 min</span>
                <span class="catalog-price">25€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Maderoterapia</span>
                <span class="catalog-duration">45 min</span>
                <span class="catalog-price">34,90€</span>
              </div>
              <div class="catalog-row">
                <span class="catalog-name">Drenaje linfático manual</span>
                <span class="catalog-duration">45 min</span>
                <span class="catalog-price">44€</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ── MASAJES ── -->
        <div class="catalog-panel" id="cat-masajes" role="tabpanel" aria-labelledby="tab-masajes">
          <div class="catalog-rows">
            <div class="catalog-row">
              <span class="catalog-name">Full Body</span>
              <span class="catalog-duration">60 min</span>
              <span class="catalog-price">55€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Espalda</span>
              <span class="catalog-duration">30 min</span>
              <span class="catalog-price">35€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Craneofacial</span>
              <span class="catalog-duration">20 min</span>
              <span class="catalog-price">25€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Piernas</span>
              <span class="catalog-duration">45 min</span>
              <span class="catalog-price">40€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Pies</span>
              <span class="catalog-duration">30 min</span>
              <span class="catalog-price">20€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Masaje sensorial</span>
              <span class="catalog-duration">30 min</span>
              <span class="catalog-price">45€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Craneofacial + Presoterapia</span>
              <span class="catalog-duration">30 min</span>
              <span class="catalog-price">45€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Masaje parejas (pack champagne)</span>
              <span class="catalog-duration">—</span>
              <span class="catalog-price">120€</span>
            </div>
          </div>
        </div>

        <!-- ── MANICURA ── -->
        <div class="catalog-panel" id="cat-manicura" role="tabpanel" aria-labelledby="tab-manicura">
          <div class="catalog-rows">
            <div class="catalog-row">
              <span class="catalog-name">Manicura clásica</span>
              <span class="catalog-duration">30 min</span>
              <span class="catalog-price">14,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Semipermanente</span>
              <span class="catalog-duration">45 min</span>
              <span class="catalog-price">17,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Semipermanente con refuerzo</span>
              <span class="catalog-duration">60 min</span>
              <span class="catalog-price">21,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Baño de gel</span>
              <span class="catalog-duration">75 min</span>
              <span class="catalog-price">25€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Baño de acrílico</span>
              <span class="catalog-duration">75 min</span>
              <span class="catalog-price">30€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Relleno gel</span>
              <span class="catalog-duration">60 min</span>
              <span class="catalog-price">25€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Relleno acrílico</span>
              <span class="catalog-duration">60 min</span>
              <span class="catalog-price">30€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Set gel</span>
              <span class="catalog-duration">90 min</span>
              <span class="catalog-price">32€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Set acrílico primera puesta</span>
              <span class="catalog-duration">90 min</span>
              <span class="catalog-price">37,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Retirada acrílico/gel</span>
              <span class="catalog-duration">20 min</span>
              <span class="catalog-price">15,90€</span>
            </div>
          </div>
          <div class="catalog-extras">
            Extras: <strong>Francesa</strong> 3,50€ &nbsp;|&nbsp; <strong>Decoración básica</strong> 0,50€/uña &nbsp;|&nbsp; <strong>Decoración 3D</strong> 1€/uña
          </div>
        </div>

        <!-- ── PEDICURA ── -->
        <div class="catalog-panel" id="cat-pedicura" role="tabpanel" aria-labelledby="tab-pedicura">
          <div class="catalog-rows">
            <div class="catalog-row">
              <span class="catalog-name">Permanente</span>
              <span class="catalog-duration">30 min</span>
              <span class="catalog-price">20€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Pedicura SPA + Permanente</span>
              <span class="catalog-duration">45 min</span>
              <span class="catalog-price">25,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Completa Especial MōMa</span>
              <span class="catalog-duration">60 min</span>
              <span class="catalog-price">35,50€</span>
            </div>
          </div>
        </div>

        <!-- ── MANIPEDI ── -->
        <div class="catalog-panel" id="cat-manipedi" role="tabpanel" aria-labelledby="tab-manipedi">
          <div class="catalog-rows">
            <div class="catalog-row">
              <span class="catalog-name">Mani Pedi Tradicional</span>
              <span class="catalog-duration">35 min</span>
              <span class="catalog-price">25,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Mani Pedi Permanente</span>
              <span class="catalog-duration">90 min</span>
              <span class="catalog-price">38,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Mani Pedi Especial MōMa</span>
              <span class="catalog-duration">105 min</span>
              <span class="catalog-price">48,50€</span>
            </div>
          </div>
        </div>

        <!-- ── DEPILACIÓN LÁSER ── -->
        <div class="catalog-panel" id="cat-laser" role="tabpanel" aria-labelledby="tab-laser">
          <p class="catalog-laser-intro">Láser indoloro, apto para todos los fototipos de piel.</p>
          <div class="catalog-subgroup-block">
            <h3 class="catalog-subgroup">Zona Pequeña</h3>
            <p class="catalog-laser-zones">Labio · Mentón · Areolas · Manos · Pies · Patillas · Perianal</p>
            <div class="catalog-rows">
              <div class="catalog-row">
                <span class="catalog-name">Precio por sesión</span>
                <span class="catalog-duration">—</span>
                <span class="catalog-price">9,90€</span>
              </div>
            </div>
          </div>
          <div class="catalog-subgroup-block">
            <h3 class="catalog-subgroup">Zona Mediana</h3>
            <p class="catalog-laser-zones">Axilas · Ingles · Medias piernas · Medios brazos · Cara</p>
            <div class="catalog-rows">
              <div class="catalog-row">
                <span class="catalog-name">Precio por sesión</span>
                <span class="catalog-duration">—</span>
                <span class="catalog-price">23,50€</span>
              </div>
            </div>
          </div>
          <div class="catalog-subgroup-block">
            <h3 class="catalog-subgroup">Zona Grande</h3>
            <p class="catalog-laser-zones">Piernas completas · Brazos completos · Pecho · Hombros · Espalda · Torso</p>
            <div class="catalog-rows">
              <div class="catalog-row">
                <span class="catalog-name">Precio por sesión</span>
                <span class="catalog-duration">—</span>
                <span class="catalog-price">35,50€</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ── CEJAS & BEAUTY ── -->
        <div class="catalog-panel" id="cat-cejas" role="tabpanel" aria-labelledby="tab-cejas">
          <div class="catalog-rows">
            <div class="catalog-row">
              <span class="catalog-name">Depilación de cejas</span>
              <span class="catalog-duration">—</span>
              <span class="catalog-price">6,50€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Diseño y depilación de cejas</span>
              <span class="catalog-duration">—</span>
              <span class="catalog-price">12,50€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Diseño de cejas + tinte</span>
              <span class="catalog-duration">—</span>
              <span class="catalog-price">18,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Lifting de pestañas</span>
              <span class="catalog-duration">45 min</span>
              <span class="catalog-price">25€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Laminado de cejas</span>
              <span class="catalog-duration">45 min</span>
              <span class="catalog-price">27,90€</span>
            </div>
            <div class="catalog-row">
              <span class="catalog-name">Microneedling ác. hialurónico (labios)</span>
              <span class="catalog-duration">20 min</span>
              <span class="catalog-price">30€</span>
            </div>
          </div>
        </div>

      </div><!-- /.catalog-panels -->
    </div>
  </section>

  <!-- ============================
       CTA INTERMEDIO — Gradient Border
  ============================= -->
  <section class="cta-mid-section" aria-label="Primera consulta gratuita">
    <div class="cta-mid-inner">
      <div class="cta-gradient-card reveal">
        <div class="cta-gradient-inner">
          <span class="section-tag" style="display:inline-block;margin-bottom:0.75rem">Primera Consulta</span>
          <h2 class="cta-mid-title">Tu Primera Consulta es Gratuita</h2>
          <p class="cta-mid-subtitle">
            Analizamos tu piel con tecnología avanzada y diseñamos un plan personalizado sin compromiso.
            Ven a conocernos en Calle Cruz 2, Ciudad Real.
          </p>
          <div class="cta-mid-actions">
            <a href="#contacto" class="btn-primary btn-lg">Solicitar Cita Gratuita</a>
