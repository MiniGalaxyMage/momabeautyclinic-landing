---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ============================
       NAVBAR
  ============================= -->
  <nav class="navbar" role="navigation" aria-label="Navegación principal">
    <div class="navbar-inner">
      <a href="/" class="nav-logo" aria-label="MŌMA Beauty Clinic — Inicio">MŌMA</a>

      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-links" id="navLinks" role="list">
        <li><a href="#servicios">Servicios</a></li>
        <li><a href="#equipo">Equipo</a></li>
        <li><a href="#resultados">Resultados</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>

      <a href="#contacto" class="btn-primary nav-cta-desktop">Pedir Cita</a>
    </div>
  </nav>

  <!-- ============================
       HERO
  ============================= -->
  <section class="hero" aria-label="Sección principal">
    <div class="hero-image-area">
      <img
        src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=900&q=80&auto=format&fit=crop"
        alt="Tratamiento de medicina estética en MŌMA Beauty Clinic"
        loading="eager"
        decoding="sync"
        width="900"
        height="1200"
      />
    </div>

    <div class="hero-inner">
      <div class="hero-badge reveal">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        Ciudad Real · Medicina Estética Premium
      </div>

      <h1 class="hero-title reveal reveal-delay-1">
        Medicina y Estética Avanzada en Ciudad Real
      </h1>

      <p class="hero-subtitle reveal reveal-delay-2">
        Resultados reales, elevando tu confianza. Tu mejor versión empieza con un diagnóstico personalizado.
      </p>

      <p class="hero-location reveal reveal-delay-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        Calle Cruz 2, Ciudad Real
      </p>

      <div class="hero-ctas reveal reveal-delay-3">
        <a href="#contacto" class="btn-primary">Reserva tu Consulta Gratuita</a>
        <a href="tel:+34614343492" class="btn-outline">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:inline;margin-right:0.25rem">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.1 6.1l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          614 34 34 92
        </a>
      </div>
    </div>
  </section>

  <!-- ============================
       SERVICIOS
  ============================= -->
  <section id="servicios" aria-labelledby="servicios-title">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag reveal">Tratamientos</span>
        <h2 class="section-title reveal reveal-delay-1" id="servicios-title">Nuestros Tratamientos</h2>
        <p class="section-subtitle reveal reveal-delay-2">Soluciones personalizadas para cada necesidad, con tecnología de última generación</p>
      </div>

      <div class="services-grid">
        <!-- Medicina Estética -->
        <article class="service-card reveal">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4.5 6.375a4.125 4.125 0 1 1 8.25 0 4.125 4.125 0 0 1-8.25 0ZM14.25 8.625a3.375 3.375 0 1 1 6.75 0 3.375 3.375 0 0 1-6.75 0ZM1.5 19.125a7.125 7.125 0 0 1 14.25 0v.003l-.001.119a.75.75 0 0 1-.363.63 13.067 13.067 0 0 1-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 0 1-.364-.63l-.001-.122ZM17.25 19.128l-.001.144a2.25 2.25 0 0 1-.233.96 10.088 10.088 0 0 0 5.06-1.01.75.75 0 0 0 .42-.643 4.875 4.875 0 0 0-6.957-4.611 8.586 8.586 0 0 1 1.71 5.157v.003Z"/>
            </svg>
          </div>
          <h3 class="service-name">Medicina Estética</h3>
          <p class="service-desc">Ácido hialurónico, toxina botulínica e inductores de colágeno para resultados naturales y duraderos.</p>
        </article>

        <!-- Tratamientos Faciales -->
        <article class="service-card reveal reveal-delay-1">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>
            </svg>
          </div>
          <h3 class="service-name">Tratamientos Faciales</h3>
          <p class="service-desc">Microagujas, rejuvenecimiento facial y tratamientos anti-manchas con tecnología avanzada.</p>
        </article>

        <!-- Tratamientos Corporales -->
        <article class="service-card reveal reveal-delay-2">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
            </svg>
          </div>
          <h3 class="service-name">Tratamientos Corporales</h3>
          <p class="service-desc">Adelgazamiento, reafirmación corporal y depilación láser para una figura estilizada.</p>
        </article>

        <!-- Labios & Rellenos -->
        <article class="service-card reveal">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/>
            </svg>
          </div>
          <h3 class="service-name">Labios & Rellenos</h3>
          <p class="service-desc">Aumento y perfilado natural de labios. Resultados armónicos con ácido hialurónico premium.</p>
        </article>

        <!-- Micropigmentación -->
        <article class="service-card reveal reveal-delay-1">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/>
            </svg>
          </div>
          <h3 class="service-name">Micropigmentación</h3>
          <p class="service-desc">Facial y capilar con Laura Meru, especialista con más de 5.000 clientes satisfechos.</p>
        </article>

        <!-- Nutrición -->
        <article class="service-card reveal reveal-delay-2">
          <div class="service-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/>
            </svg>
          </div>
          <h3 class="service-name">Nutrición & Bienestar</h3>
          <p class="service-desc">Asesoría nutricional personalizada con Irene. Equilibrio, nutrición deportiva y educación alimentaria.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================
       SOBRE NOSOTROS
  ============================= -->
  <section class="about-section" aria-labelledby="about-title">
    <div class="about-inner">
      <div>
        <span class="about-tag reveal">Quiénes Somos</span>
        <h2 class="about-title reveal reveal-delay-1" id="about-title">Tu mejor versión empieza aquí</h2>
        <p class="about-text reveal reveal-delay-2">
          En MŌMA creemos en la belleza 360°: entendemos cada paciente de dentro hacia fuera.
          Nuestro equipo multidisciplinar combina medicina estética avanzada, micropigmentación experta
          y nutrición personalizada para conseguir resultados naturales y duraderos.
          Trabajamos con cada persona de forma individual, diseñando protocolos a medida que
          respetan tu esencia y potencian tu confianza.
        </p>

        <div class="stats-grid reveal reveal-delay-3">
          <div class="stat-item">
            <span class="stat-number">+2000</span>
            <span class="stat-label">Pacientes atendidos</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">10+</span>
            <span class="stat-label">Años de experiencia</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">L-V</span>
            <span class="stat-label">10:00 – 20:00 h</span>
          </div>
        </div>
      </div>

      <div class="about-visual">
        <div class="about-img-placeholder reveal reveal-delay-2" aria-label="Clínica MŌMA Beauty Clinic">
          <img
            src="https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=800&q=75&auto=format&fit=crop"
            alt="Interior elegante de MŌMA Beauty Clinic en Ciudad Real"
            loading="lazy"
            decoding="async"
            width="800"
            height="1000"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       EQUIPO
  ============================= -->
  <section id="equipo" aria-labelledby="equipo-title">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag reveal">Nuestro Equipo</span>
        <h2 class="section-title reveal reveal-delay-1" id="equipo-title">Profesionales a Tu Servicio</h2>
        <p class="section-subtitle reveal reveal-delay-2">Un equipo multidisciplinar comprometido con tu bienestar y resultados</p>
      </div>

      <div class="team-grid">
        <!-- Ana -->
        <article class="team-card reveal">
          <div class="team-avatar" aria-hidden="true">A</div>
          <h3 class="team-name">Ana</h3>
          <p class="team-role">Enfermera Estética</p>
          <p class="team-bio">Especialista en medicina estética con un trato consciente y cercano. Experta en resultados naturales que potencian tu confianza sin alterar tu esencia.</p>
        </article>

        <!-- Laura Meru -->
        <article class="team-card reveal reveal-delay-1">
          <div class="team-avatar" aria-hidden="true">L</div>
          <h3 class="team-name">Laura Meru</h3>
          <p class="team-role">Micropigmentación</p>
          <p class="team-bio">Artista de la micropigmentación facial y capilar con más de 5.000 clientes satisfechos. Referente en Ciudad Real por su precisión y resultados naturales.</p>
        </article>

        <!-- Irene -->
        <article class="team-card reveal reveal-delay-2">
          <div class="team-avatar" aria-hidden="true">I</div>
          <h3 class="team-name">Irene</h3>
          <p class="team-role">Nutrición & Bienestar</p>
          <p class="team-bio">Experta en nutrición integrativa y deportiva. Te acompaña en el camino hacia el equilibrio, con planes personalizados y educación alimentaria real.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================
       RESULTADOS
  ============================= -->
  <section id="resultados" style="background: #F5F2EC;" aria-labelledby="resultados-title">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag reveal">Antes & Después</span>
        <h2 class="section-title reveal reveal-delay-1" id="resultados-title">Resultados que Hablan por Sí Solos</h2>
        <p class="section-subtitle reveal reveal-delay-2">Cada caso es único. Estos son algunos de nuestros tratamientos más solicitados.</p>
      </div>

      <div class="results-grid">
        <!-- Labios -->
        <article class="result-card reveal">
          <div class="result-card-inner">
            <div class="result-halves">
              <div class="result-before">
                <span class="result-label">Antes</span>
              </div>
              <div class="result-after">
                <span class="result-label">Después</span>
              </div>
            </div>
            <div class="result-overlay" aria-hidden="true">
              <p class="result-treatment">Labios con Ácido Hialurónico</p>
            </div>
          </div>
          <p class="sr-only">Resultado de tratamiento de labios con ácido hialurónico en MŌMA Beauty Clinic</p>
        </article>

        <!-- Rinomodelación -->
        <article class="result-card reveal reveal-delay-1">
          <div class="result-card-inner">
            <div class="result-halves">
              <div class="result-before">
                <span class="result-label">Antes</span>
              </div>
              <div class="result-after">
                <span class="result-label">Después</span>
              </div>
            </div>
            <div class="result-overlay" aria-hidden="true">
              <p class="result-treatment">Rinomodelación</p>
            </div>
          </div>
          <p class="sr-only">Resultado de rinomodelación en MŌMA Beauty Clinic</p>
        </article>

        <!-- Facial -->
        <article class="result-card reveal reveal-delay-2">
          <div class="result-card-inner">
            <div class="result-halves">
              <div class="result-before">
                <span class="result-label">Antes</span>
              </div>
              <div class="result-after">
                <span class="result-label">Después</span>
              </div>
            </div>
            <div class="result-overlay" aria-hidden="true">
              <p class="result-treatment">Tratamiento Facial Avanzado</p>
            </div>
          </div>
          <p class="sr-only">Resultado de tratamiento facial avanzado en MŌMA Beauty Clinic</p>
        </article>

        <!-- Micropigmentación -->
        <article class="result-card reveal reveal-delay-3">
          <div class="result-card-inner">
            <div class="result-halves">
              <div class="result-before">
                <span class="result-label">Antes</span>
              </div>
              <div class="result-after">
                <span class="result-label">Después</span>
              </div>
            </div>
            <div class="result-overlay" aria-hidden="true">
              <p class="result-treatment">Micropigmentación</p>
            </div>
          </div>
          <p class="sr-only">Resultado de micropigmentación en MŌMA Beauty Clinic</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================
       FORMULARIO
  ============================= -->
  <section id="contacto" class="form-section" aria-labelledby="form-title">
    <div class="section-inner">
      <div class="form-grid">
        <!-- Info lateral -->
        <div>
          <span class="section-tag reveal">Primera Consulta Gratuita</span>
          <h2 class="form-info-title reveal reveal-delay-1" id="form-title">Tu Primera Consulta es Gratuita</h2>
          <p class="form-info-sub reveal reveal-delay-2">
            Analizamos tu piel con tecnología avanzada y diseñamos un plan personalizado para ti.
            Sin compromiso. Cuéntanos qué necesitas y te llamamos.
          </p>

          <div class="form-trust-items reveal reveal-delay-3">
            <div class="form-trust-item">
              <span class="form-trust-icon" aria-hidden="true">✓</span>
              Diagnóstico personalizado sin compromiso
            </div>
            <div class="form-trust-item">
              <span class="form-trust-icon" aria-hidden="true">✓</span>
              Atendemos en 24 horas en días laborables
            </div>
            <div class="form-trust-item">
              <span class="form-trust-icon" aria-hidden="true">✓</span>
              Más de 2.000 pacientes satisfechos
            </div>
            <div class="form-trust-item">
              <span class="form-trust-icon" aria-hidden="true">✓</span>
              Clínica en Calle Cruz 2, Ciudad Real
            </div>
          </div>
        </div>

        <!-- Formulario -->
        <div class="reveal reveal-delay-2">
          <form
            class="contact-form"
            name="cita-moma"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/gracias"
            novalidate
          >
            <input type="hidden" name="form-name" value="cita-moma" />
            <input type="hidden" name="bot-field" aria-hidden="true" />
            <input type="hidden" name="utm_source" />
            <input type="hidden" name="utm_campaign" />
            <input type="hidden" name="utm_medium" />

            <div class="form-row">
              <div class="form-group">
                <label for="nombre">Nombre *</label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  placeholder="Tu nombre"
                  required
                  autocomplete="given-name"
                />
              </div>
              <div class="form-group">
                <label for="telefono">Teléfono *</label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  placeholder="6XX XXX XXX"
                  required
                  autocomplete="tel"
                />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="tu@email.com"
                autocomplete="email"
              />
            </div>

            <div class="form-group">
              <label for="servicio">Servicio de interés</label>
              <select id="servicio" name="servicio">
                <option value="">Selecciona un tratamiento</option>
                <option value="medicina-estetica">Medicina Estética</option>
                <option value="tratamiento-facial">Tratamiento Facial / Microagujas</option>
                <option value="tratamiento-corporal">Tratamiento Corporal</option>
                <option value="labios-rellenos">Labios & Rellenos</option>
                <option value="micropigmentacion">Micropigmentación</option>
                <option value="nutricion">Nutrición & Bienestar</option>
                <option value="otro">Otro / No sé aún</option>
              </select>
            </div>

            <div class="form-group">
              <label for="mensaje">Mensaje (opcional)</label>
              <textarea
                id="mensaje"
                name="mensaje"
                placeholder="Cuéntanos qué necesitas o qué dudas tienes..."
              ></textarea>
            </div>

            <div class="form-checkbox">
              <input type="checkbox" id="privacidad" name="privacidad" required />
              <label for="privacidad">
                Acepto la <a href="/privacidad" target="_blank" rel="noopener">política de privacidad</a>
                y consiento el tratamiento de mis datos para gestionar mi consulta. *
              </label>
            </div>

            <button type="submit" class="btn-primary form-submit">
              Solicitar Cita Gratuita
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       FOOTER
  ============================= -->
  <footer aria-label="Pie de página">
    <div class="footer-inner">
      <!-- Columna marca -->
      <div>
        <p class="footer-brand-name">MŌMA</p>
        <p class="footer-tagline">
          Medicina Estética & Bienestar en Ciudad Real.<br/>
          Tu mejor versión, con resultados naturales.
        </p>

        <a href="tel:+34614343492" class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
          </svg>
          614 34 34 92
        </a>

